{
  "name": "painrelief-ai",
  "version": "1.0.0",
  "description": "PainRelief AI - Smart Health Assistant for Pain Management",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:frontend": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "psql -U postgres -f database_schema.sql",
    "db:reset": "psql -U postgres -d postgres -c \"DROP DATABASE IF EXISTS painrelief_ai;\" && npm run db:init",
    "db:backup": "pg_dump painrelief_ai > backups/painrelief_ai_$(date +%Y%m%d_%H%M%S).sql",
    "db:migrate": "node scripts/migrate.js",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "seed": "node scripts/seed.js",
    "seed:exercises": "node scripts/seed-exercises.js",
    "seed:medications": "node scripts/seed-medications.js",
    "api:docs": "node scripts/generate-docs.js",
    "docker:build": "docker build -t painrelief-ai .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "deploy": "npm run build && npm run db:migrate && npm start",
    "deploy:staging": "npm run build && npm run test && git push heroku-staging main",
    "deploy:production": "npm run build && npm run test && git push heroku-production main",
    "health-check": "curl http://localhost:5000/api/health",
    "logs": "tail -f logs/app.log",
    "monitor": "pm2 start server.js --name 'painrelief-ai' --watch"
  },
  "keywords": [
    "health",
    "pain-management",
    "ai",
    "healthcare",
    "saas",
    "fitness",
    "wellness"
  ],
  "author": "PainRelief AI Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.10.0",
    "pg-pool": "^3.6.1",
    "@anthropic-ai/sdk": "^0.13.3",
    "axios": "^1.5.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "http-status-codes": "^2.2.0",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "stripe": "^13.10.0",
    "razorpay": "^2.9.1",
    "nodemailer": "^6.9.6",
    "node-schedule": "^2.1.0",
    "redis": "^4.6.11",
    "bull": "^4.11.3",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1493.0",
    "@google-cloud/storage": "^6.9.0",
    "sharp": "^0.32.6",
    "pdfkit": "^0.13.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.0.0",
    "joi": "^17.11.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "lucide-react": "^0.302.0",
    "recharts": "^2.10.0",
    "zustand": "^4.4.2",
    "react-query": "^3.39.3",
    "axios-instance": "^1.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1",
    "@vitejs/plugin-react": "^4.1.0",
    "vite": "^5.0.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/jest-dom": "^6.1.4",
    "cypress": "^13.6.0",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "jest-postgresql": "^1.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/painrelief-ai.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/painrelief-ai/issues"
  },
  "homepage": "https://github.com/yourusername/painrelief-ai#readme",
  "maintainers": [
    {
      "name": "Your Name",
      "email": "your@email.com",
      "url": "https://yourwebsite.com"
    }
  ]
}
